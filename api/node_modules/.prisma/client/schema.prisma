model aspnet_Users {
  ApplicationId                 String?                         @db.UniqueIdentifier
  UserId                        String                          @id(clustered: false, map: "PK__aspnet_U__1788CC4D0BC6C43E") @default(dbgenerated("newid()"), map: "DF__aspnet_Us__UserI__0EA330E9") @db.UniqueIdentifier
  UserName                      String?                         @db.NVarChar(256)
  LoweredUserName               String?                         @db.NVarChar(256)
  MobileAlias                   String?                         @db.NVarChar(16)
  IsAnonymous                   Boolean?                        @default(false, map: "DF__aspnet_Us__IsAno__108B795B")
  LastActivityDate              DateTime?                       @db.DateTime
  Name                          String?                         @db.NVarChar(50)
  LastName                      String?                         @db.NVarChar(50)
  Email                         String?                         @db.NVarChar(80)
  FonctionID                    Int?
  ServiceID                     Int?
  statut                        Boolean?
  aspnet_PersonalizationPerUser aspnet_PersonalizationPerUser[]
