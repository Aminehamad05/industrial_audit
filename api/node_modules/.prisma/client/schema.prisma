generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model audits {
  id                 Int       @id(map: "PK_audits") @default(autoincrement())
  auditType          String?   @map("audit_type") @db.NVarChar(100)
  auditTypeName      String?   @map("audit_type_name") @db.NVarChar(200)
  auditTarget        String?   @map("audit_target") @db.NVarChar(100)
  auditorLogin       String?   @map("auditor_login") @db.NVarChar(50)
  auditorFullName    String?   @map("auditor_full_name") @db.NVarChar(100)
  startDate          DateTime? @map("start_date") @db.DateTime
  endDate            DateTime? @map("end_date") @db.DateTime
  score              Decimal?  @map("score") @db.Decimal(18, 3)
  comment            String?   @map("comment") @db.NVarChar(200)
  auditTargetArea    String?   @map("audit_target_area") @db.NVarChar(100)
  auditTargetSubarea String?   @map("audit_target_subarea") @db.NVarChar(100)
  auditTargetSection String?   @map("audit_target_section") @db.NVarChar(100)
  auditShiftName     String?   @map("audit_shift_name") @db.NVarChar(20)
  supervisorName     String?   @map("supervisor") @db.NVarChar(150)
  supervisorLogin    String?   @map("supervisorlogin") @db.NVarChar(100)
  plantId            Int?      @map("idplant")
  matricule          String?   @map("Matricule") @db.NVarChar(100)
  TeamLeader         Int?
  scheduleId         Int?      @map("id_Schedule")
}

model audit_details {
  id               Int     @id(map: "PK_audit_details") @default(autoincrement())
  auditId          Int     @map("audit_id")
  groupPosition    Int     @map("group_position")
  groupName        String  @map("group_name") @db.NVarChar(100)
  groupNameEng     String  @map("group_name_ENG") @db.NVarChar(100)
  questionPosition Int     @map("question_position")
  question         String  @map("question") @db.NVarChar(800)
  questionEng      String  @map("question_ENG") @db.NVarChar(800)
  answer           String? @map("answer") @db.NVarChar(100)
  comment          String? @map("comment") @db.NVarChar(200)
  answerOk         Boolean @map("answer_OK")
  answerNok        Boolean @map("answer_NOK")
  answerNc         Boolean @map("answer_NC")
  answerNa         Boolean @map("answer_NA")
  plantId          Int?    @map("id_plant")
  photoPath        String? @map("Photo_Path") @db.NVarChar(100)
}

model actions {
  id                  Int       @id(map: "PK_actions") @default(autoincrement())
  auditId             Int       @map("audit_id")
  auditDetailId       Int       @map("audit_detail_id")
  statusId            Int?      @map("id_status")
  responsibleLogin    String    @map("responsible_login") @db.NVarChar(50)
  responsibleFullName String    @map("responsible_full_name") @db.NVarChar(100)
  description         String?   @map("action") @db.NVarChar(200)
  plannedTerm         DateTime? @map("planned_term") @db.Date
  term                DateTime? @map("term") @db.Date
  lastEditDate        DateTime? @map("last_edit_date") @db.DateTime
  lastEditedByUser    String?   @map("user_action") @db.NVarChar(50)
  plantId             Int?      @map("idPlant")
  cause               String?   @map("cause") @db.NVarChar(50)
}

model schedules {
  id                 Int       @id(map: "PK_schedules") @default(autoincrement())
  scheduleName       String    @map("schedule_name") @db.NVarChar(200)
  auditType          String    @map("audit_type") @db.NVarChar(200)
  auditTarget        String?   @map("audit_target") @db.NVarChar(200)
  auditDate          DateTime? @map("audit_date") @db.Date
  auditYear          Int?      @map("audit_year")
  auditMonth         Int?      @map("audit_month")
  auditWeek          Int?      @map("audit_week")
  auditor_login      String?   @db.NVarChar(200)
  auditTargetSubarea String?   @map("audit_target_subarea") @db.NVarChar(200)
  auditTargetArea    String?   @map("audit_target_area") @db.NVarChar(200)
  plantId            Int?      @map("idPlant")
  status             Int?      @map("audit_status")
  section            String?   @map("section") @db.NVarChar(200)
}

model AffectationUserUserChef {
  idaffectuser Int     @id(map: "PK_AffectationUserUserChef") @default(autoincrement())
  UserId       String? @db.NVarChar(50)
  UserIdSup    String? @db.NVarChar(50)
  idPlant      Int?
}

model aspnet_Applications {
  ApplicationName        String              @unique(map: "UQ__aspnet_A__3091033107020F21") @db.NVarChar(256)
  LoweredApplicationName String              @unique(map: "UQ__aspnet_A__17477DE40425A276") @db.NVarChar(256)
  ApplicationId          String              @id(clustered: false, map: "PK__aspnet_A__C93A4C98014935CB") @default(dbgenerated("newid()"), map: "DF__aspnet_Ap__Appli__08EA5793") @db.UniqueIdentifier
  Description            String?             @db.NVarChar(256)
  aspnet_Membership      aspnet_Membership[]
  aspnet_Paths           aspnet_Paths[]
  aspnet_Roles           aspnet_Roles[]
  aspnet_Users           aspnet_Users[]
}

model aspnet_Membership {
  ApplicationId                          String              @db.UniqueIdentifier
  UserId                                 String              @id(clustered: false, map: "PK__aspnet_M__1788CC4D1FCDBCEB") @db.UniqueIdentifier
  Password                               String              @db.NVarChar(128)
  PasswordFormat                         Int                 @default(0, map: "DF__aspnet_Me__Passw__239E4DCF")
  PasswordSalt                           String              @db.NVarChar(128)
  MobilePIN                              String?             @db.NVarChar(16)
  Email                                  String?             @db.NVarChar(256)
  LoweredEmail                           String?             @db.NVarChar(256)
  PasswordQuestion                       String?             @db.NVarChar(256)
  PasswordAnswer                         String?             @db.NVarChar(128)
  IsApproved                             Boolean
  IsLockedOut                            Boolean
  CreateDate                             DateTime            @db.DateTime
  LastLoginDate                          DateTime            @db.DateTime
  LastPasswordChangedDate                DateTime            @db.DateTime
  LastLockoutDate                        DateTime            @db.DateTime
  FailedPasswordAttemptCount             Int
  FailedPasswordAttemptWindowStart       DateTime            @db.DateTime
  FailedPasswordAnswerAttemptCount       Int
  FailedPasswordAnswerAttemptWindowStart DateTime            @db.DateTime
  Comment                                String?             @db.NText
  idPlant                                Int?
  aspnet_Applications                    aspnet_Applications @relation(fields: [ApplicationId], references: [ApplicationId], onUpdate: NoAction, map: "FK__aspnet_Me__Appli__21B6055D")
}

model aspnet_Paths {
  ApplicationId                  String                          @db.UniqueIdentifier
  PathId                         String                          @id(clustered: false, map: "PK__aspnet_P__CD67DC5859063A47") @default(dbgenerated("newid()"), map: "DF__aspnet_Pa__PathI__5BE2A6F2") @db.UniqueIdentifier
  Path                           String                          @db.NVarChar(256)
  LoweredPath                    String                          @db.NVarChar(256)
  aspnet_Applications            aspnet_Applications             @relation(fields: [ApplicationId], references: [ApplicationId], onUpdate: NoAction, map: "FK__aspnet_Pa__Appli__5AEE82B9")
  aspnet_PersonalizationAllUsers aspnet_PersonalizationAllUsers?
  aspnet_PersonalizationPerUser  aspnet_PersonalizationPerUser[]
}

model aspnet_PersonalizationAllUsers {
  PathId          String       @id(map: "PK__aspnet_P__CD67DC5960A75C0F") @db.UniqueIdentifier
  PageSettings    Bytes        @db.Image
  LastUpdatedDate DateTime     @db.DateTime
  aspnet_Paths    aspnet_Paths @relation(fields: [PathId], references: [PathId], onUpdate: NoAction, map: "FK__aspnet_Pe__PathI__0F624AF8")
}

model aspnet_PersonalizationPerUser {
  Id              String        @id(clustered: false, map: "PK__aspnet_P__3214EC06656C112C") @default(dbgenerated("newid()"), map: "DF__aspnet_Perso__Id__6754599E") @db.UniqueIdentifier
  PathId          String?       @db.UniqueIdentifier
  UserId          String?       @db.UniqueIdentifier
  PageSettings    Bytes         @db.Image
  LastUpdatedDate DateTime      @db.DateTime
  aspnet_Paths    aspnet_Paths? @relation(fields: [PathId], references: [PathId], onDelete: NoAction, onUpdate: NoAction, map: "FK__aspnet_Pe__PathI__123EB7A3")
  aspnet_Users    aspnet_Users? @relation(fields: [UserId], references: [UserId], onDelete: NoAction, onUpdate: NoAction, map: "FK__aspnet_Pe__UserI__693CA210")
}

model aspnet_Profile {
  UserId               String       @id(map: "PK__aspnet_P__1788CC4C36B12243") @db.UniqueIdentifier
  PropertyNames        String       @db.NText
  PropertyValuesString String       @db.NText
  PropertyValuesBinary Bytes        @db.Image
  LastUpdatedDate      DateTime     @db.DateTime
  aspnet_Users         aspnet_Users @relation(fields: [UserId], references: [UserId], onUpdate: NoAction, map: "FK__aspnet_Pr__UserI__38996AB5")
}

model aspnet_Roles {
  ApplicationId       String                @db.UniqueIdentifier
  RoleId              String                @id(clustered: false, map: "PK__aspnet_R__8AFACE1B4222D4EF") @default(dbgenerated("newid()"), map: "DF__aspnet_Ro__RoleI__44FF419A") @db.UniqueIdentifier
  RoleName            String                @db.NVarChar(256)
  LoweredRoleName     String                @db.NVarChar(256)
  Description         String?               @db.NVarChar(256)
  idPlant             Int?
  aspnet_Applications aspnet_Applications   @relation(fields: [ApplicationId], references: [ApplicationId], onUpdate: NoAction, map: "FK__aspnet_Ro__Appli__440B1D61")
  aspnet_UsersInRoles aspnet_UsersInRoles[]
}

model aspnet_SchemaVersions {
  Feature                 String  @db.NVarChar(128)
